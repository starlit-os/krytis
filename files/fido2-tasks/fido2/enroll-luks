#!/usr/bin/env bash
#MISE description="Enroll a FIDO2 security key as a LUKS2 unlock factor via systemd-cryptenroll"

set -euo pipefail

if [[ $EUID -ne 0 ]]; then
  echo "This task enrolls a LUKS token — run as root: sudo mise fido2:enroll-luks" >&2
  exit 1
fi

# Collect LUKS devices from /etc/crypttab
LUKS_DEVICES=()
if [[ -f /etc/crypttab ]]; then
  while IFS= read -r line; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ -z "${line// /}" ]] && continue
    DEVICE=$(awk '{print $2}' <<< "$line")
    # crypttab commonly uses UUID= syntax; resolve to a path cryptsetup can open
    if [[ "$DEVICE" =~ ^UUID= ]]; then
      DEVICE="/dev/disk/by-uuid/${DEVICE#UUID=}"
    fi
    cryptsetup isLuks "$DEVICE" 2>/dev/null && LUKS_DEVICES+=("$DEVICE") || true
  done < /etc/crypttab
fi

# Fresh bootc installs have no /etc/crypttab — fall back to block device scan
if [[ ${#LUKS_DEVICES[@]} -eq 0 ]]; then
  while IFS= read -r dev; do
    [[ -n "$dev" ]] && LUKS_DEVICES+=("$dev")
  done < <(blkid -t TYPE=crypto_LUKS -o device 2>/dev/null | sort)
fi

if [[ ${#LUKS_DEVICES[@]} -eq 0 ]]; then
  echo "No LUKS devices found (checked /etc/crypttab and blkid scan)" >&2
  exit 1
fi

if [[ ${#LUKS_DEVICES[@]} -eq 1 ]]; then
  DEVICE="${LUKS_DEVICES[0]}"
else
  echo "LUKS devices:"
  for i in "${!LUKS_DEVICES[@]}"; do
    echo "  $i) ${LUKS_DEVICES[$i]}"
  done
  read -rp "Select device [0-$((${#LUKS_DEVICES[@]}-1))]: " IDX
  DEVICE="${LUKS_DEVICES[$IDX]}"
fi

echo ""
read -rp "Enroll FIDO2 key on ${DEVICE}? [y/N] " CONFIRM
if [[ ! "$CONFIRM" =~ ^[yY]$ ]]; then
  echo "Aborted."
  exit 0
fi

echo "Touch your security key when it blinks..."
systemd-cryptenroll --fido2-device=auto "$DEVICE"

# rd.luks.options=fido2-device=auto is baked into every image build via
# /usr/lib/bootc/kargs.d/30-fido2-luks.toml (files/bootc-config/), so no
# runtime karg step is needed here. It's a no-op for LUKS volumes without a
# systemd-fido2 token enrolled.
echo "Enrolled. Verify with: mise fido2:status"
