#!/usr/bin/env bash
#MISE description="Verify pam_u2f is wired and prompt a live sudo escalation to test it"

set -euo pipefail

PAM_FILE="/etc/pam.d/password-auth"
MODULE="pam_u2f.so"

echo "=== PAM config ==="
if grep -q "$MODULE" "$PAM_FILE" 2>/dev/null; then
  echo "  ok  ${MODULE} found in ${PAM_FILE}"
  grep "$MODULE" "$PAM_FILE" | sed 's/^/      /'
else
  echo "  FAIL  ${MODULE} not in ${PAM_FILE}" >&2
  echo "        Is config/u2f-config.bst installed in the image?" >&2
  exit 1
fi

echo ""
echo "=== Module on disk ==="
# pam_u2f installs to %{libdir}/security, which is the multiarch path
# (e.g. /usr/lib/x86_64-linux-gnu/security) — don't hardcode /usr/lib/security.
MODULE_PATH=$(find /usr/lib -name "$MODULE" 2>/dev/null | head -1)
if [[ -n "$MODULE_PATH" ]]; then
  echo "  ok  ${MODULE_PATH}"
else
  echo "  FAIL  ${MODULE} not found under /usr/lib" >&2
  echo "        Is core/pam-u2f installed in the image?" >&2
  exit 1
fi

echo ""
echo "=== Live sudo test ==="
echo "  Running: sudo -k true"
echo "  Touch your FIDO2 key if prompted..."
sudo -k true && echo "  ok  sudo succeeded" || { echo "  FAIL  sudo returned $?" >&2; exit 1; }
