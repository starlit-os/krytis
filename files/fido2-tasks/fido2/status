#!/usr/bin/env bash
#MISE description="Show enrolled FIDO2 keys for sudo/login and LUKS slots"

set -euo pipefail

AUTHFILE="${XDG_CONFIG_HOME:-${HOME}/.config}/Yubico/u2f_keys"

echo "=== sudo / PAM keys (${AUTHFILE}) ==="
if [[ -s "$AUTHFILE" ]]; then
  while IFS= read -r line; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ -z "${line// /}" ]] && continue
    USERNAME="${line%%:*}"
    NUM_KEYS=$(tr ':' '\n' <<< "$line" | tail -n +2 | wc -l)
    echo "  ${USERNAME}: ${NUM_KEYS} key(s)"
  done < "$AUTHFILE"
else
  echo "  (no keys enrolled — run: mise fido2:enroll)"
fi

echo ""
echo "=== LUKS FIDO2 slots ==="

LUKS_DEVICES=()
if [[ -f /etc/crypttab ]]; then
  while IFS= read -r line; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ -z "${line// /}" ]] && continue
    DEVICE=$(awk '{print $2}' <<< "$line")
    if [[ "$DEVICE" =~ ^UUID= ]]; then
      DEVICE="/dev/disk/by-uuid/${DEVICE#UUID=}"
    fi
    cryptsetup isLuks "$DEVICE" 2>/dev/null && LUKS_DEVICES+=("$DEVICE") || true
  done < /etc/crypttab
fi

if [[ ${#LUKS_DEVICES[@]} -eq 0 ]]; then
  while IFS= read -r dev; do
    [[ -n "$dev" ]] && LUKS_DEVICES+=("$dev")
  done < <(blkid -t TYPE=crypto_LUKS -o device 2>/dev/null | sort)
fi

if [[ ${#LUKS_DEVICES[@]} -eq 0 ]]; then
  echo "  (no LUKS devices found)"
else
  for DEVICE in "${LUKS_DEVICES[@]}"; do
    echo "  ${DEVICE}:"
    systemd-cryptenroll "$DEVICE" 2>/dev/null | sed 's/^/    /' || true
  done
fi
