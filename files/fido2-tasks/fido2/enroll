#!/usr/bin/env bash
#MISE description="Enroll a FIDO2 security key for sudo / login (writes to ~/.config/Yubico/u2f_keys)"

set -euo pipefail

AUTHFILE="${XDG_CONFIG_HOME:-${HOME}/.config}/Yubico/u2f_keys"
ORIGIN="pam://$(hostname)"

echo "Enrolling FIDO2 key for ${USER} (origin: ${ORIGIN})"
echo "(If your key has no PIN yet, set one first with: ykman fido access change-pin)"

# Detect if this physical key is already enrolled: pamu2fcfg -t verifies the
# key against all existing credentials in the authfile (requires one touch).
if [[ -s "$AUTHFILE" ]]; then
  echo "Checking existing credentials — touch your key if it blinks..."
  if pamu2fcfg -o "$ORIGIN" -t 2>/dev/null; then
    if ! gum confirm "This key is already enrolled. Replace it?"; then
      echo "Aborted."
      exit 0
    fi
    # Remove all credentials for this user; re-enroll below with fresh -P cred.
    sed -i "/^${USER}:/d" "$AUTHFILE"
    echo "Removed existing credentials for ${USER}."
  fi
fi

echo "Touch your key when it blinks (you will be asked for your PIN first)..."

# -P: enroll with pin-verification required — must match the pinverification
# option in /etc/pam.d/system-auth and /etc/pam.d/greetd.
NEW_LINE=$(pamu2fcfg -o "$ORIGIN" -P)
NEW_CRED="${NEW_LINE#*:}"  # strip "username:" prefix

mkdir -p "$(dirname "$AUTHFILE")"
touch -a "$AUTHFILE"
chmod 600 "$AUTHFILE"

if grep -q "^${USER}:" "$AUTHFILE"; then
  # Multi-key: append new credential to the existing line
  sed -i "s|^${USER}:.*$|&:${NEW_CRED}|" "$AUTHFILE"
  KEY_COUNT=$(grep "^${USER}:" "$AUTHFILE" | tr ':' '\n' | tail -n +2 | wc -l)
  echo "Added key — ${USER} now has ${KEY_COUNT} enrolled key(s)"
else
  echo "$NEW_LINE" >> "$AUTHFILE"
  echo "Enrolled first key for ${USER}"
fi

echo "Key stored in: ${AUTHFILE}"
