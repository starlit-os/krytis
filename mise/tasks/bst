#!/usr/bin/env bash
#MISE description="Run any bst command (native uv venv by default; --container for podman)"
#MISE depends=["generate-image-version"]
#USAGE flag "--container" help="Use the pinned bst2 podman container instead of native BST"
#USAGE arg "<args>" var=#true help="bst subcommand and arguments (e.g. build stacks/base-system.bst)"

# BST_FLAGS: appended to default flags; BST_FLAGS_OVERRIDE: replaces all defaults.
# BST_CACHE_QUOTA: override the local CAS quota (default 40G).
set -euo pipefail

DEFAULT_FLAGS="-o x86_64_v3 true --no-interactive"
BST_CACHE_QUOTA="${BST_CACHE_QUOTA:-50G}"

if [ -n "${BST_FLAGS_OVERRIDE:-}" ]; then
    FLAGS="${BST_FLAGS_OVERRIDE}"
else
    FLAGS="${DEFAULT_FLAGS} ${BST_FLAGS:-}"
fi

# usage_container is set by mise when invoked via `mise run bst --container` (and
# is inherited by child processes, so a parent task like validate may also set it).
# When a parent task passes --container as a literal first arg to this script,
# consume it here regardless — mise already stripped it from $@ for the direct case.
CONTAINER="${usage_container:-false}"
if [ "${1:-}" = "--container" ]; then
    CONTAINER=true
    shift
fi

# BST_CONTAINER=true in .mise.local.toml [env] is the workstation-wide default for
# machines without native BST host deps. Explicit --container (above) always wins.
if [ "$CONTAINER" != "true" ] && [ "${BST_CONTAINER:-false}" = "true" ]; then
    CONTAINER=true
fi

if [ "$CONTAINER" = "true" ]; then
    mkdir -p "${HOME}/.cache/buildstream"
    # word-splitting on FLAGS is intentional (space-separated option flags)
    # shellcheck disable=SC2086
    exec podman run --rm \
        --privileged \
        --device /dev/fuse \
        --network=host \
        --memory "${BST_MEMORY_LIMIT}" \
        -v "$(pwd):/src:rw" \
        -v "${HOME}/.cache/buildstream:/root/.cache/buildstream:rw" \
        -w /src \
        "${BST2_IMAGE}" \
        bash -c 'mkdir -p /root/.config/buildstream
printf "cache:\n  quota: %s\n" "$1" > /root/.config/buildstream/user.conf
shift; bst --colors "$@"' -- "${BST_CACHE_QUOTA}" ${FLAGS} "$@"
fi

# Native path: write quota to user.conf if not already set.
USER_CONF="${HOME}/.config/buildstream/user.conf"
if ! grep -q "quota:" "${USER_CONF}" 2>/dev/null; then
    mkdir -p "$(dirname "${USER_CONF}")"
    printf '\ncache:\n  quota: %s\n' "${BST_CACHE_QUOTA}" >> "${USER_CONF}"
fi

# shellcheck disable=SC2086
exec uv run bst --colors ${FLAGS} "$@"
