#!/usr/bin/env bash
#MISE description="Update gum element to the latest GitHub release"

set -euo pipefail

ELEMENT="elements/core/gum.bst"
REPO="charmbracelet/gum"

echo "==> Fetching latest ${REPO} release..."
LATEST_TAG=$(gh api "repos/${REPO}/releases/latest" --jq '.tag_name')
LATEST_VER="${LATEST_TAG#v}"

echo "==> Latest: ${LATEST_TAG}"

CURRENT_VER=$(grep -oP 'gum_\K[^_]+(?=_Linux)' "${ELEMENT}" | head -1)
echo "==> Current: ${CURRENT_VER}"

if [ "${LATEST_VER}" = "${CURRENT_VER}" ]; then
  echo "==> Already up to date (${CURRENT_VER})"
  exit 0
fi

TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

X64_FILE="gum_${LATEST_VER}_Linux_x86_64.tar.gz"
ARM64_FILE="gum_${LATEST_VER}_Linux_arm64.tar.gz"
BASE_URL="https://github.com/${REPO}/releases/download/${LATEST_TAG}"

echo "==> Downloading ${X64_FILE}..."
curl -sSL "${BASE_URL}/${X64_FILE}" -o "${TMPDIR}/${X64_FILE}"
X64_SHA=$(sha256sum "${TMPDIR}/${X64_FILE}" | awk '{print $1}')
echo "    sha256=${X64_SHA}"

echo "==> Downloading ${ARM64_FILE}..."
curl -sSL "${BASE_URL}/${ARM64_FILE}" -o "${TMPDIR}/${ARM64_FILE}"
ARM64_SHA=$(sha256sum "${TMPDIR}/${ARM64_FILE}" | awk '{print $1}')
echo "    sha256=${ARM64_SHA}"

CURRENT_X64_SHA=$(grep -A2 'x86_64' "${ELEMENT}" | grep 'ref:' | awk '{print $2}')
CURRENT_ARM64_SHA=$(grep -A2 'arm64' "${ELEMENT}" | grep 'ref:' | awk '{print $2}')

echo "==> Updating ${ELEMENT}: ${CURRENT_VER} → ${LATEST_VER}"

sed -i "s|gum_${CURRENT_VER}_Linux|gum_${LATEST_VER}_Linux|g" "${ELEMENT}"
sed -i "s|/v${CURRENT_VER}/|/v${LATEST_VER}/|g" "${ELEMENT}"
sed -i "s|ref: ${CURRENT_X64_SHA}|ref: ${X64_SHA}|" "${ELEMENT}"
sed -i "s|ref: ${CURRENT_ARM64_SHA}|ref: ${ARM64_SHA}|" "${ELEMENT}"

echo "==> Done. Run 'mise run validate' to verify."
