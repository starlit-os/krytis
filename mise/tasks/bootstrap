#!/usr/bin/env bash
# MISE description="Post-hook called by 'mise bootstrap' — enables experimental features"
# The mise built-in 'mise bootstrap' runs [bootstrap.packages] + tool install, then calls
# this task. Do NOT call 'mise bootstrap' here — that would recurse infinitely.
set -euo pipefail

# Enable experimental: required for [deps.uv] auto = true.
# This is idempotent and safe to re-run.
mise settings experimental=true

# Generate include/image-version.yml — gitignored so not committed.
mise run generate-image-version

echo "==> Bootstrap complete."
