#!/usr/bin/env bash
#MISE description="Install/refresh the Buildbarn CAS quadlet units (rootless, systemctl --user) and reload systemd"

set -euo pipefail

QUADLET_SRC="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../../quadlet/buildbarn" && pwd)"
QUADLET_DEST="${HOME}/.config/containers/systemd"
DATA_DIR="${HOME}/.local/share/buildbarn"

if [ ! -f "${DATA_DIR}/certs/ca.crt" ]; then
    echo "ERROR: ${DATA_DIR}/certs/ca.crt not found."
    echo "       Run 'mise buildbarn:certs-init' first to provision local TLS material."
    exit 1
fi

echo "==> Copying quadlet units to ${QUADLET_DEST}..."
mkdir -p "${QUADLET_DEST}"
cp "${QUADLET_SRC}"/*.network "${QUADLET_SRC}"/*.container "${QUADLET_SRC}"/*.volume "${QUADLET_DEST}/"

echo "==> Copying jsonnet config to ${DATA_DIR}/config..."
mkdir -p "${DATA_DIR}/config"
cp "${QUADLET_SRC}"/config/*.jsonnet "${QUADLET_SRC}"/config/*.libsonnet "${DATA_DIR}/config/"

echo "==> Reloading user systemd units..."
systemctl --user daemon-reload

echo "==> Enabling + starting bb-storage and bb-asset..."
systemctl --user enable --now bb-storage.service bb-asset.service

echo "==> Done. Use 'mise buildbarn:status' / 'mise buildbarn:logs' to check."
echo "    Note: rootless user services stop when your session ends unless"
echo "    'loginctl enable-linger \$USER' has been run."
