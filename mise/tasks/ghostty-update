#!/usr/bin/env python3
"""
Update ghostty.bst to the latest release.

Parses build.zig.zon from the new source tarball, downloads every dep
tarball listed there, computes SHA256 for BST, and rewrites the sources
section in elements/desktop/ghostty.bst.
"""

import hashlib
import json
import os
import re
import subprocess
import sys
import tarfile
import tempfile
import urllib.request
from pathlib import Path

ELEMENT = Path("elements/desktop/ghostty.bst")
ZIG_ELEMENT = Path("elements/desktop/zig.bst")
REPO = "ghostty-org/ghostty"

# Alias mappings matching include/aliases.yml (longest prefix first)
URL_ALIASES = [
    ("https://deps.files.ghostty.org/", "ghostty_deps:"),
    ("https://release.files.ghostty.org/", "ghostty_releases:"),
    ("https://github.com/", "github_files:"),
]


def apply_alias(url: str) -> str:
    for prefix, alias in URL_ALIASES:
        if url.startswith(prefix):
            return alias + url[len(prefix):]
    return url


def sha256_file(path: str) -> str:
    h = hashlib.sha256()
    with open(path, "rb") as f:
        for chunk in iter(lambda: f.read(65536), b""):
            h.update(chunk)
    return h.hexdigest()


def download(url: str, dest: str) -> None:
    print(f"      {url.rsplit('/', 1)[-1]}")
    req = urllib.request.Request(url, headers={"User-Agent": "ghostty-update/1.0"})
    with urllib.request.urlopen(req) as resp, open(dest, "wb") as out:
        while chunk := resp.read(65536):
            out.write(chunk)


def gh_latest_tag(repo: str) -> str:
    # ghostty does not publish GitHub releases — only git tags.
    # Fetch all tag names (paginated) and filter for semver in Python.
    result = subprocess.run(
        ["gh", "api", f"repos/{repo}/tags", "--paginate", "--jq", ".[].name"],
        capture_output=True, text=True, check=True,
    )
    semver_re = re.compile(r"^v(\d+)\.(\d+)\.(\d+)$")
    tags = [
        (int(m.group(1)), int(m.group(2)), int(m.group(3)), line.strip())
        for line in result.stdout.splitlines()
        if (m := semver_re.match(line.strip()))
    ]
    if not tags:
        sys.exit(f"ERROR: no semver tags found in {repo}")
    tags.sort(reverse=True)
    return tags[0][3]


def parse_zon_deps(content: str) -> list[tuple[str, str]]:
    """Extract (url, zig_hash) pairs from build.zig.zon.

    Handles both:
      .dep = .{ .url = "...", .hash = "..." }   (single-line or multi-line)
    """
    pairs = []
    # Find every block that has both .url and .hash fields
    block_re = re.compile(
        r'\.url\s*=\s*"([^"]+)"[^}]*?\.hash\s*=\s*"([^"]+)"',
        re.DOTALL,
    )
    for m in block_re.finditer(content):
        pairs.append((m.group(1), m.group(2)))
    return pairs


def current_version() -> str:
    text = ELEMENT.read_text()
    m = re.search(r'ghostty_releases:\S+/ghostty-(\S+?)\.tar\.gz', text)
    if not m:
        sys.exit("ERROR: could not find current version in element")
    return m.group(1)


def main() -> None:
    print(f"==> Fetching latest {REPO} release...")
    latest_tag = gh_latest_tag(REPO)
    latest_ver = latest_tag.lstrip("v")
    cur_ver = current_version()

    print(f"==> Latest: {latest_tag}  Current: {cur_ver}")
    if latest_ver == cur_ver:
        print(f"==> Already up to date ({cur_ver})")
        return

    with tempfile.TemporaryDirectory() as tmpdir:
        # ── Source tarball ──────────────────────────────────────────────────
        src_url = f"https://release.files.ghostty.org/{latest_ver}/ghostty-{latest_ver}.tar.gz"
        src_file = os.path.join(tmpdir, "ghostty-src.tar.gz")
        print(f"==> Downloading source tarball...")
        download(src_url, src_file)
        src_sha = sha256_file(src_file)
        print(f"    sha256={src_sha}")

        # ── Extract build.zig.zon ───────────────────────────────────────────
        print("==> Parsing build.zig.zon...")
        with tarfile.open(src_file, "r:gz") as tf:
            zon_member = next(
                (m for m in tf.getmembers() if m.name.endswith("build.zig.zon")),
                None,
            )
            if not zon_member:
                sys.exit("ERROR: build.zig.zon not found in source tarball")
            with tf.extractfile(zon_member) as f:
                zon = f.read().decode()

        # minimum_zig_version check
        mzv = re.search(r'\.minimum_zig_version\s*=\s*"([^"]+)"', zon)
        min_zig = mzv.group(1) if mzv else None

        deps = parse_zon_deps(zon)
        print(f"    {len(deps)} deps found")

        # ── Download every dep and compute SHA256 ──────────────────────────
        print("==> Downloading dep tarballs...")
        entries: list[tuple[str, str, str]] = []  # (aliased_url, sha256, directory)

        for url, _zig_hash in deps:
            filename = url.rsplit("/", 1)[-1]
            dep_file = os.path.join(tmpdir, filename)
            download(url, dep_file)
            dep_sha = sha256_file(dep_file)
            aliased = apply_alias(url)

            # git repo archives go in zig-deps-git; CDN tarballs in zig-deps
            if "github.com" in url and "/archive/" in url:
                directory = "zig-deps-git"
            else:
                directory = "zig-deps"

            entries.append((aliased, dep_sha, directory))

    # ── Rebuild sources section ─────────────────────────────────────────────
    print("==> Regenerating sources section...")
    new_src_alias = f"ghostty_releases:{latest_ver}/ghostty-{latest_ver}.tar.gz"

    lines: list[str] = [
        "sources:",
        "  # Ghostty source tarball",
        f"  - kind: tar",
        f"    url: {new_src_alias}",
        f"    ref: {src_sha}",
        "",
        "  # Zig package dependencies",
    ]
    for aliased, sha, directory in entries:
        lines += [
            "  - kind: remote",
            f"    url: {aliased}",
            f"    ref: {sha}",
            f"    directory: {directory}",
            "",
        ]

    new_sources = "\n".join(lines)

    # Replace sources: ... config: block
    text = ELEMENT.read_text()
    new_text = re.sub(
        r"^sources:.*?(?=^config:)",
        new_sources + "\n",
        text,
        flags=re.DOTALL | re.MULTILINE,
        count=1,
    )

    # Update -Dversion-string=
    new_text = new_text.replace(
        f"-Dversion-string={cur_ver}",
        f"-Dversion-string={latest_ver}",
    )

    ELEMENT.write_text(new_text)
    print(f"==> Updated {ELEMENT}: {cur_ver} → {latest_ver} ({len(entries)} deps)")

    # ── Zig version check ───────────────────────────────────────────────────
    if min_zig:
        zig_text = ZIG_ELEMENT.read_text()
        mz = re.search(r"zig-x86_64-linux-([0-9]+\.[0-9]+\.[0-9]+)\.tar", zig_text)
        cur_zig = mz.group(1) if mz else None
        if cur_zig and cur_zig != min_zig:
            print(
                f"==> WARNING: zig.bst has {cur_zig} but ghostty {latest_ver} requires"
                f" minimum_zig_version={min_zig}. Manual zig.bst update may be needed."
            )

    print("==> Done. Run 'mise run validate' to verify.")


if __name__ == "__main__":
    main()
