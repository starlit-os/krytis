#!/usr/bin/env bash
#MISE description="Update include/image-version.yml from git history; run before builds in CI"

# Tasks run from config_root by default, so relative paths resolve to the project root.
set -euo pipefail
IMAGE_VERSION=$(git log -1 --format=%cd --date=format:%Y%m%d%H%M)
COMMIT=$(git rev-parse HEAD)
cat > include/image-version.yml <<EOF
# Generated by \`mise run generate-image-version\`. Do not edit by hand.
image-version: 'dev.${IMAGE_VERSION}'
commit: '${COMMIT}'
EOF
echo "==> Updated include/image-version.yml: dev.${IMAGE_VERSION} @ ${COMMIT:0:12}"
