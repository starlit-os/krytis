    - /usr/bin/tail
    - /usr/bin/tee
    - /usr/bin/test
    - /usr/bin/timeout
    - /usr/bin/touch
    - /usr/bin/tr
    - /usr/bin/true
    - /usr/bin/truncate
    - /usr/bin/tsort
    - /usr/bin/tty
    - /usr/bin/uname
