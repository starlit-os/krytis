    - /usr/bin/paste
    - /usr/bin/pathchk
    - /usr/bin/pinky
    - /usr/bin/pr
    - /usr/bin/printenv
    - /usr/bin/printf
    - /usr/bin/ptx
    - /usr/bin/pwd
    - /usr/bin/readlink
    - /usr/bin/realpath
    - /usr/bin/rmdir
    - /usr/bin/seq
    - /usr/bin/sha1sum
    - /usr/bin/sha224sum
    - /usr/bin/sha256sum
    - /usr/bin/sha384sum
    - /usr/bin/sha512sum
