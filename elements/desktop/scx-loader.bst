kind: manual

# scx_loader v1.1.1 — D-Bus on-demand loader of sched-ext schedulers.
# Required by falcond for per-game CPU scheduler switching via the org.scx.Loader
# D-Bus interface. Source: https://github.com/sched-ext/scx-loader

build-depends:
- freedesktop-sdk.bst:components/rust.bst
- freedesktop-sdk.bst:public-stacks/buildsystem-make.bst

depends:
- freedesktop-sdk.bst:public-stacks/runtime-minimal.bst

variables:
  cargo-home: '%{build-root}/.cargo'

config:
  build-commands:
  - |
    export CARGO_HOME="%{cargo-home}"
    cargo build --release --locked -p scx_loader

  install-commands:
  - install -Dm755 target/release/scx_loader "%{install-root}%{bindir}/scx_loader"

  - |
    install -Dm644 services/scx_loader.service \
      "%{install-root}%{indep-libdir}/systemd/system/scx_loader.service"

  - |
    install -Dm644 services/org.scx.Loader.service \
      "%{install-root}%{datadir}/dbus-1/system-services/org.scx.Loader.service"

  - |
    install -Dm644 configs/org.scx.Loader.conf \
      "%{install-root}%{datadir}/dbus-1/system.d/org.scx.Loader.conf"

  - |
    install -Dm644 configs/org.scx.Loader.xml \
      "%{install-root}%{datadir}/dbus-1/interfaces/org.scx.Loader.xml"

  - |
    install -Dm644 configs/org.scx.Loader.policy \
      "%{install-root}%{datadir}/polkit-1/actions/org.scx.Loader.policy"

  - |
    install -Dm644 configs/scx_loader.toml \
      "%{install-root}%{datadir}/scx_loader/config.toml"

  - |
    install -Dm644 /dev/stdin \
      "%{install-root}%{indep-libdir}/systemd/system-preset/71-krytis-scx-loader.preset" <<'EOF'
    enable scx_loader.service
    EOF

